<aura:component implements="force:appHostable,flexipage:availableForAllPageTypes,force:lightningQuickAction" 
                controller="NewStockReqController" access="global" >
    <aura:attribute name="stockList" type="List" />
    
    <aura:attribute name="showReq" type="boolean" default="false"/>
    <aura:attribute name="SelectedProducts" type="Object[]"  />
    <aura:attribute name="stockRequests" type="Object[]"  />
     <aura:attribute name="spinner" type="boolean" default="false"/>
    
    <aura:attribute name="data" type="Object"/>
    <aura:attribute name="dataSort" type="Object"/>
    <aura:attribute name="columns" type="List"/>
    <aura:attribute name="m_SearchKeyword" type="String"/>
    <aura:attribute name="searchKeyword" type="String"/>
    <aura:attribute name="searchKeyword2" type="String"/>
    <aura:attribute name="searchKeyword3" type="String"/>
    <aura:attribute name="pageNumber" type="Integer" default="1"/>    
    <aura:attribute name="totalPage" type="Integer" default="1"/>
    <aura:attribute name="totalRecords" type="Integer" default="0"/>
    <aura:attribute name="pageSize" type="Integer" default="15"/>
    <aura:attribute name="isLastPage" type="Boolean" default="true"/>
    <aura:attribute name="dataSize" type="Integer" default="0"/> 
    <aura:attribute name="sortBy" type="String" default="Name"/>
    <aura:attribute name="sortDirection" type="String" default="asc"/>
    <aura:attribute name="condition" type="Boolean"/>
    <aura:attribute name="searchType" type="string" default=""/>
    <aura:attribute name="modal" type="Boolean" default="false"/>
    <aura:attribute name="Name" type="String" />
    <aura:attribute name="code" type="String"/>
    <aura:attribute name="desc" type="String"/>
    <aura:attribute name="unit" type="String"/>
    <aura:attribute name="fixed" type="String"/>
    <aura:attribute name="category" type="String"/>
    <aura:attribute name="isDesktop" type="boolean"/>
    <aura:attribute name="isMobile1" type="boolean"/>
    <aura:attribute name="selectedRows" type="List" access="PRIVATE"/>
    
    <lightning:spinner variant="brand" size="large" aura:id="Id_spinner" class="slds-hide" />
    
    <!-- Handlers -->
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"></aura:handler>
    
    <div class="slds-tabs_card">
        <div class="slds-page-header">
            <div class="slds-page-header__row">
                <div class="slds-page-header__col-title">
                    <div class="slds-media">
                        <div class="slds-media__figure">
                            <span class="slds-icon_container slds-icon-standard-opportunity">
                                <lightning:icon iconName="utility:cart" alternativeText="Event" title="Event" />
                            </span>
                        </div>
                        <div class="slds-media__body">
                            <div class="slds-page-header__name">
                                <div class="slds-page-header__name-title">
                                    <h1>
                                        <span>Seraphine</span>
                                        <span class="slds-page-header__title slds-truncate" title="New Stock Request">New Stock Request</span>
                                    </h1>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div> <br/>
    
     <aura:if isTrue="{!v.showReq == false}">
    <lightning:card title="Search by one of the following Product fields." iconName="standard:product_request">
        <aura:if isTrue="{!v.isDesktop}">
            <lightning:layout>
                <lightning:layoutItem size="3" padding="around-small">
                    <div style="font-weight:bold">
                        <lightning:input value="{!v.searchKeyword}" onchange="{!c.onSearchChange}"  label="Product Name" placeholder="Enter Product Name" minlength="3"
                                         aura:id="searchField" messageWhenTooShort="Minimum of 3 characters required to search"/>
                    </div>
                </lightning:layoutItem>
                <lightning:layoutItem size="3" padding="around-small">
                    <div style="font-weight:bold">
                        <lightning:input value="{!v.searchKeyword2}"  onchange="{!c.onSearchChange}"  label="Product Code" placeholder="Enter Product Code" minlength="3"
                                         aura:id="searchField2" messageWhenTooShort="Minimum of 3 characters required to search"/>
                    </div>
                </lightning:layoutItem>
                
                <lightning:layoutItem size="3" padding="around-small">
                    <lightning:button onclick="{!c.Search}"
                                      variant="brand"
                                      label="Search" class="searchbtn"
                                      iconName="utility:search"/> 
                </lightning:layoutItem>
            </lightning:layout>
        </aura:if>
        <aura:if isTrue="{!v.isMobile1}">
            <lightning:layout>
                <lightning:layoutItem size="12" padding="around-small">
                    <lightning:select aura:id="selectSearchType" onchange="{!c.onSearchType}">
                        <option value="NONE">Select Search Type</option>
                        <option value="Name">Product Name</option>
                        <option value="Code">Product Code</option>
                    </lightning:select>
                </lightning:layoutItem> 
            </lightning:layout>
            <lightning:layout>
                <lightning:layoutItem size="12" padding="around-small">
                    <div style="font-weight:bold">
                        <lightning:input value="{!v.m_SearchKeyword}"  disabled="true" label="" placeholder="Enter Search Text" minlength="3"
                                         aura:id="m_SearchField" messageWhenTooShort="At least 3 character required to search"/>
                    </div>
                </lightning:layoutItem>
            </lightning:layout>
            <lightning:layout>
                <lightning:layoutItem size="12" padding="around-small">
                    <lightning:button disabled="true" aura:id="m_SearchButton" onclick="{!c.SearchMobile}"
                                      variant="brand"
                                      label="Search" class="searchbtn MButton"
                                      iconName="utility:search"/> 
                </lightning:layoutItem>
            </lightning:layout>
        </aura:if>
        <aura:if isTrue="{!v.condition}">
            <p class="slds-p-horizontal_small">
                
                <div class="myTest" >
                    <div class="slds-clearfix">
                        <div class="slds-page-header" role="banner">
                            <p class="slds-page-header__title">Products</p>
                        </div>
                    </div>
                    
                    <lightning:datatable aura:id = "accDT"
                                         columns = "{!v.columns}"
                                         maxRowSelection="{!v.maxRowSelection}"
                                         data = "{!v.data}"
                                         keyField = "Id"
                                         selectedRows = "{!v.selectedRows}"
                                         sortedBy="{!v.sortBy}"
                                         sortedDirection="{!v.sortDirection}"
                                         onsort="{!c.handleSort}"
                                         onrowaction="{! c.handleRowAction }"
                                         onrowselection="{! c.updateSelectedText }"/>
                    
                    <div class="slds-clearfix">
                        <div class="slds-page-header" role="banner">
                            <aura:if isTrue="{!v.isDesktop}">
                                <!--  Pagination Buttons Start -->
                                <div class="slds-align_absolute-center">         
                                    <lightning:button label="Prev" iconName="utility:back" iconPosition="left"
                                                      onclick="{!c.handlePrev}" disabled="{! v.pageNumber == 1}" variant="brand"/>
                                    
                                    <span class="slds-badge slds-badge_lightest"
                                          style="margin-right: 10px;margin-left: 10px;">
                                        {!(v.pageNumber)+' of '+(v.totalPage)+' pages'} &nbsp;&nbsp;&nbsp;&nbsp;{! ((v.pageNumber-1)*v.pageSize+v.dataSize)+' of '+(v.totalRecords)+' records'}
                                    </span>
                                    
                                    <lightning:button label="Next" iconName="utility:forward" iconPosition="right"
                                                      disabled="{! v.isLastPage}" onclick="{!c.handleNext}" variant="brand"/>
                                </div>  
                                <!--  Pagination Buttons End -->
                                
                            </aura:if>
                            <aura:if isTrue="{!v.isMobile1}">
                                <div class="slds-align_absolute-center">
                                    <lightning:button label="Prev" iconName="utility:chevronleft" iconPosition="left" onclick="{!c.handlePrev}" disabled="{! v.pageNumber == 1}"/>
                                    <div style="padding:0px 10px">
                                        {! ((v.pageNumber-1)*v.pageSize+v.dataSize)+' of '+(v.totalRecords)+' records'}
                                    </div>
                                    <lightning:button label="Next" iconName="utility:chevronright" iconPosition="right" disabled="{! v.isLastPage}" onclick="{!c.handleNext}"/>
                                </div>
                            </aura:if>
                        </div>
                    </div>
                </div>
            </p>
        </aura:if>
        
        <!--Modal Screen -->
        <aura:if isTrue="{!v.modal}">
            <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open slds-modal_large">
                <div class="slds-modal__container">
                    
                    <header class="slds-modal__header">
                        <lightning:buttonIcon iconName="utility:close"
                                              onclick="{! c.closeModel }"
                                              alternativeText="close"
                                              variant="bare-inverse"
                                              class="slds-modal__close"/>
                        <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">Product Details</h2>
                    </header>
                    <!--###### MODAL BOX BODY Part Start######-->
                    <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                        <p>Product Name : {!(v.Name)}</p><br></br>
                        <p>Product Code : {!(v.code)}</p><br></br>
                        <p>Description : {!(v.desc)}</p><br></br>
                       <!-- <p>Unit : {!(v.unit)}</p><br></br>
                        <p>Category : {!(v.category)}</p><br></br>-->
                         <aura:if isTrue="{!v.fixed == 'Y'}"><span style="font-size:9px;color:red">* This is a fixed price item.</span></aura:if>
                        
                    </div>
                    
                    
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
        </aura:if>
        
        <footer class="slds-modal__footer">
            <lightning:button variant="brand" label="Next" title="Next" onclick="{! c.NextClick }" />
            <lightning:button variant="destructive" label="Cancel" title="Cancel" onclick="{! c.cancel }" />
            
        </footer>
        
    </lightning:card>
    </aura:if>
         
    <aura:if isTrue="{!v.showReq}">
        <lightning:card>
            <table > 
                <tbody>      
                    <aura:iteration items="{!v.stockRequests}" var="req" indexVar="index">
                        <tr>
                            <td> 
                                <lightning:card class="slds-p-left_xx-small groove">
                                    <div class="slds-grid slds-wrap slds-grid_pull-padded-x-small">
                                        
                                        
                                        <div class="slds-size_1-of-3 slds-p-horizontal_small">
                                        	 <lightning:input value="{!req.Name}" aura:id="enter-search" name="enter-search" label="{!index+1+(') Name')}" type="text" disabled="true"/>
                                            
                                        </div>
                                        
                                        <div class="slds-size_1-of-3 slds-p-horizontal_small">
                                            <lightning:input name="prodCode" type="text"  label="Product Code" value="{!req.Item_Code__c}" disabled="true"/> 
                                        </div>
                                        <div class="slds-size_1-of-3 slds-p-horizontal_small" data-record="{!index}">
                                            <lightning:input name="prdQty" type="number" label="Quantity" value="{!req.Quantity__c}" />
                                        </div>
                                       
                                    </div>
                                    
                                </lightning:card>
                            </td>
                        </tr>
                    </aura:iteration>
                </tbody>
            </table>
            <footer class="slds-modal__footer">
                <lightning:button variant="brand" label="Previous" title="Previous" onclick="{! c.prev }" />
                <lightning:button variant="brand" label="Save" title="Save" onclick="{! c.save }" aura:id="disablebuttonid" />
                <lightning:button variant="destructive" label="Cancel" title="Cancel" onclick="{! c.cancel }" />
                
            </footer>
        </lightning:card>
    </aura:if>
    
    
    <!-- spinner -->
    <div>
        <aura:if isTrue="{!v.spinner}">
            <lightning:spinner class="spins" size="large" variant="brand" alternativeText="Loading" />
        </aura:if>
    </div>
    
    <!--  <div aura:id="visitMnager" class="slds-grid slds-wrap slds-grid_pull-padded-x-small">
        <div class="slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-horizontal_x-small">
            
            <table > 
                
                <tbody>  
                    <lightning:card iconName="standard:work_order_item" class="slds-p-left_xx-small groove">
                        <b>Select Products</b>    <br/> <br/>
                     
                        <aura:iteration items="{!v.stockList}" var="sl">
                            <lightning:input type="checkbox" label="{!sl.Name}" name="{!sl.Name}"  value="{!sl.Id}" onchange="{! c.handleChange1 }" />
                        </aura:iteration><br/>
                        
                                           
                    </lightning:card>
                </tbody>
            </table>
        </div>
    </div>-->
</aura:component>