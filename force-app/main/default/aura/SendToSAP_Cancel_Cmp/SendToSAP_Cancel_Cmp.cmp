<aura:component controller="SAPsend_TriggerHandler" implements="force:lightningQuickActionwithoutheader,force:appHostable,force:hasRecordId" access="global" >
	    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
      <div role="dialog" tabindex="-1" class="slds-modal slds-fade-in-open">
            <div class="slds-modal__container " style="width:100%;">
                <div class="slds-modal__content slds-p-around--medium slds-is-relative">
                        <div class="slds-spinner_container">
                            <div class="slds-spinner--brand slds-spinner slds-spinner--small" role="alert">
                                <span class="slds-assistive-text">Loading...</span>
                                <div class="slds-spinner__dot-a"></div>
                                <div class="slds-spinner__dot-b"></div>
                            </div>
                        </div>
                </div>
        </div>
    </div>
 
</aura:component>