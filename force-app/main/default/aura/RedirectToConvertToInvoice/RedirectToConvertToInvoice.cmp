<aura:component controller="SalesOrderItemListCtrl" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global" >
    <aura:attribute name="sObjectName" type="String" /> 
    <aura:attribute name="recordId" type="String" />
    <aura:attribute name="redirect" type="Boolean" default="true"/>
    <aura:attribute name="cashDiscount2" type="Decimal" default="0.00"/>
	<aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
</aura:component>