<aura:component    controller="MessagingUtility" implements="force:lightningQuickAction,force:hasRecordId" access="global" >
    <aura:attribute name="recordId" type="string"/>
    <aura:attribute name="emailBody" type="string"/>
    <aura:attribute name="email" type="string"/>
    <aura:attribute name="showAlert" type="Boolean" default="false" />
     <aura:attribute name="isInnerPopupOpen" type="Boolean" default="false"/>
    <aura:attribute name="isMainPopupOpen" type="Boolean" default="false"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" /> 
    <aura:html tag="style">
        .panel.slds-modal > .modal-container{
        width: 75%;
        max-width: 70rem;
        }
    </aura:html>
    
    <!-- Main Popup -->
    <aura:if isTrue="{!v.isMainPopupOpen}">
        <section role="dialog" tabindex="-1" class="slds-modal slds-fade-in-open">
            <header class="slds-modal__header"> <h2 class="slds-text-heading_medium slds-hyphenate">Invoice PDF</h2> </header>
            <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                <iframe src="{!'https://seraphinedevimpexpvtltd2--sbox1--c.sandbox.vf.force.com/apex/InvoicePDFDraft?id=' + v.recordId}" width="100%" height="500px;" frameBorder="0"/> 
 <!-- Inner Popup -->
                <aura:if isTrue="{!v.isInnerPopupOpen}">
                    <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open slds-backdrop slds-backdrop--open">
                        <div class="slds-modal__container">
                            <lightning:buttonIcon iconName="utility:close"  onclick="{!c.closeInnerPop}"  alternativeText="close"  variant="bare-inverse"  class="slds-modal__close"/>
                            <header class="slds-modal__header">   <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate">Confirm Email Details</h2> </header>
                            <div class="slds-modal__content slds-p-around_medium " id="modal-content-id-1">
                                
                                <lightning:input type="email" name="email6" required="true"  value="{!v.email}" label="Receipent Email" />
                                <lightning:textarea name="input1" maxlength="1300" label="Email Body" value="{!v.emailBody}"/>
                            </div>
                            <footer class="slds-modal__footer">
                                <button class="slds-button slds-button_neutral" onclick="{!c.closeInnerPop}">Cancel</button>
                                <button class="slds-button slds-button_neutral slds-button_brand" variant="brand" onclick="{!c.handleSend}">Send Email</button>
                            </footer>
                        </div>
                    </section>  
                </aura:if>
                <!-- Inner Popup -->
            </div>
            <footer class="slds-modal__footer">
                <button class="slds-button slds-button_neutral" onclick="{!c.closeOuterPopup}">Cancel</button>
                <button class="slds-button slds-button_neutral slds-button_brand" variant="brand" onclick="{!c.openSendEmail}">Send Email</button>
            </footer>
        </section>
    </aura:if>
                   
</aura:component>