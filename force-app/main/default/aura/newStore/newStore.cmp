                </aura:if>
            </div>-->
            <!--<div class="slds-grid">
                <div class="slds-col slds-size_1-of-2">
                    <lightning:select aura:id="field1" name="selectCategory" label="Store Category" value="{!v.account.Store_Category__c}" required="true" messageWhenValueMissing="Select store category">
                        <option value="">choose one...</option>
                        <option value="Hyper market">Hyper market</option>
                        <option value="super market">super market</option>
                        <option value="consumer store">consumer store</option>
                        <option value="Hotel">Hotel</option>
                        <option value="Bakery">Bakery</option>
                        <option value="Whole sale shop">Whole sale shop</option>
                        <option value="Distributor">Distributor</option>
                    </lightning:select></div> &nbsp;
                <div class="slds-col slds-size_1-of-2">
                    <lightning:select aura:id="field1" name="selectGrade" label="Grade"  value="{!v.account.Grade__c}" required="true" messageWhenValueMissing="Select Grade">
                        <option value="">choose one...</option>
                        <option value="A">A</option>
                        <option value="B">B</option>
                        <option value="C">C</option>
                        <option value="D">D</option>
                    </lightning:select></div>
            </div>-->
            <!--<div class="slds-grid">
                <div class="slds-col slds-size_1-of-2">
                    
                </div>&nbsp;

            </div>-->
            <div class="slds-grid">
                <div class="slds-col slds-size_1-of-2">
                    <lightning:input aura:id="field1" label="Pan Number" pattern="[A-Z]{5}[0-9]{4}[A-Z]{1}"
                                     messageWhenPatternMismatch="Enter a valid PAN number" type="text"
                                     value="{!v.account.Pan_Number__c}" />
                </div>&nbsp;
                <div class="slds-col slds-size_1-of-2">
                    <lightning:select aura:id="field1" name="Customer Type" label="Customer Type" value="{!v.account.CustomerType__c}" required="true">
                        <option value="">choose one...</option>
                        <aura:iteration items="{!v.customerTypes}" var="item">
                            <option value="{!item.value}">{!item.label}</option>
                        </aura:iteration>
                    </lightning:select>
                    <!--<lightning:select aura:id="field1" name="Type" label="Customer Type" value="{!v.account.Type}">
                        <option value="">choose one...</option>
                        <option value="Analyst">Analyst</option>
                        <option value="Competitor">Competitor</option>
                        <option value="Customer">Customer</option>
                        <option value="Integrator">Integrator</option>
                        <option value="Investor">Investor</option>
                        <option value="Partner">Partner</option>
                        <option value="Press">Press</option>
                        <option value="Prospect">Prospect</option>
                        <option value="Reseller">Reseller</option>
                        <option value="Other">Other</option>
                    </lightning:select>-->
                </div>
            </div>
            <!--<div class="slds-grid">
                <lightning:input type="checkbox" label="GST applicable" name="input1" checked="{!v.account.GST_applicable__c}" onchange="{!c.handleCheckboxChange}"/>
            </div>
            <aura:if isTrue="{!v.isChecked}">
                <div class="slds-grid">
                    <div class="slds-col slds-size_1-of-2">
                        <lightning:input label="GST" type="text" required="true"
                                         pattern="^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[1-9A-Z]{1}Z[0-9A-Z]{1}$"
                                         messageWhenPatternMismatch="Enter a valid GST number" aura:id="field1" minlength="15"
                                         maxlength="15" value="{!v.account.GST__c}"
                                         messageWhenTooShort="Please enter valid 15digit GST" />
                    </div>&nbsp;
                    <div class="slds-col slds-size_1-of-2">
                        <lightning:select aura:id="field1" name="GST Type" label="GST Type"
                                          value="{!v.account.GST_Type__c}">
                            <option value="">choose one...</option>
                            <option value="CGST">CGST</option>
                            <option value="SGST">SGST</option>
                            <option value="IGST">IGST</option>
                            <option value="UTGST/UGST">UTGST/UGST</option>
                        </lightning:select>
                    </div>
                </div>
                
            </aura:if>-->
            
            <div class="slds-grid">
                <div class="slds-col slds-size_1-of-2">
                    <lightning:select aura:id="field1" name="Card Type" label="Card Type" required="true"
                                      value="{!v.account.CardType__c}" messageWhenValueMissing="Enter card type" >
                        <option value="">choose one...</option>
                        <option value="C">C</option>
                    </lightning:select>
                </div>
                &nbsp;
                <div class="slds-col slds-size_1-of-2">
                    <lightning:input label="Customer Group Code" type="text" aura:id="field1" required="true"
                                     value="{!v.account.CustomerGroupCode__c}" messageWhenValueMissing="Enter customer group code" />
                </div>
                
            </div>
            <div class="slds-grid">
                <div class="slds-col slds-size_1-of-2">
                    <lightning:input label="Opening Balance" type="number" formatter="currency"
                                     value="{!v.account.Opening_Balance__c}" />
                </div>
                &nbsp;
                <div class="slds-col slds-size_1-of-2">
                    
                    <lightning:input value="{!v.accountSearchText}" aura:id="enter-search" name="enter-search"
                                     label="Parent Customer" type="search" />
                    <div class="slds-form-element slds-m-bottom__medium">
                        <div class="slds-form-element__control">
                            <ul class="slds-lookup__list" role="listbox">
                                <aura:if isTrue="{!v.matchAccounts}">
                                    <div class="{!if(not(empty(v.matchAccounts)), 'result-buttom slds-card','')}">
                                        <aura:iteration items="{!v.matchAccounts}" var="item">
                                            <li role="presentation">
                                                <span class="slds-lookup__item-action slds-media slds-media__center"
                                                      role="option">
                                                    <div class="slds-media__body">
                                                        <div class="slds-input-has-icon slds-input-has-icon__right">
                                                            <div class="slds-lookup__result-text" data-id="{!item.Id}"
                                                                 onclick="{!c.updateAccount}">
                                                                <a role="option">
                                                                    <lightning:icon iconName="standard:account"
                                                                                    size="xx-small" />&nbsp;{!item.Name}
                                                                </a>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </span>
                                            </li>
                                        </aura:iteration>
                                    </div>
                                </aura:if>
                            </ul>
                        </div>
                    </div>
                    
                </div>
            </div>
            &nbsp;
            <div class="slds-grid ">
             
                <div class="slds-col slds-size_1-of-2 ">
                 
                    <label class="slds-form-element__label" for="unique-id-of-input">GST applicable</label>
                   <lightning:input type="checkbox"  name="input1" checked="{!v.account.GST_applicable__c}" onchange="{!c.handleCheckboxChange}"/>
                </div>  
                  <div class="slds-col slds-size_1-of-2">
                    <lightning:select aura:id="field1" name="State" label="Customer State"  required="true"
                                      value="{!v.account.State__c}" messageWhenValueMissing="Enter customer state" >
                      <option value="">choose one...</option>
                        <aura:iteration items="{!v.StatePicklist1}" var="item">
                        <option value="{!item.value}">{!item.label}</option>
                      
                        </aura:iteration>
                    </lightning:select>
                </div>
            </div>
                     <div class="slds-grid ">
                <div class="slds-col slds-size_1-of-2 ">
                    <label class="slds-form-element__label" for="unique-id-of-input">IGST Intrastate Applicable</label>
                   <lightning:input type="checkbox"  name="input1" checked="{!v.account.IgstOnIntra__c}" />
                </div>  
                  <div class="slds-col slds-size_1-of-2">
                       <label class="slds-form-element__label" for="unique-id-of-input">Don't Apply FIFO</label>
                      <lightning:input type="checkbox"  name="input2" checked="{!v.account.Don_t_Apply_FIFO__c}" />
                </div>
                <!--<div class="slds-col slds-size_1-of-2">
                    <lightning:input label="Street Name" type="text"  value="{!v.account.Street_Name__c}"/>
                </div>-->
                <!--<div class="slds-col slds-size_1-of-2">
                    <lightning:input label="Panchayath"  type="text" value="{!v.account.Panchayath__c}" />
                </div>-->
            </div>
            <!--<div class="slds-grid">
                <div class="slds-col slds-size_1-of-2">
                    <lightning:select label="State" value="{!v.account.State__c}" onchange="{!c.getdisricts}">
                        <option value="">Choose one..</option>
                        <aura:iteration items="{!v.StatePicklist}" var="val">
                            <option value="{!val}"> {!val}</option>
                        </aura:iteration>
                    </lightning:select>  
                </div>
                &nbsp;
                <div class="slds-col slds-size_1-of-2">
                    <lightning:select label="District" value="{!v.account.District__c}" onchange="{!c.getdisricts}">
                        <option value="">Choose one..</option>
                        <aura:iteration items="{!v.DistPicklist}" var="val">
                            <option value="{!val}"> {!val}</option>
                        </aura:iteration>
                    </lightning:select>  
                </div>
                
            </div>-->
            
            <!--<div class="slds-grid">
                <div class="slds-col slds-size_1-of-2">
                    <lightning:input label="Pincode" required="true" type="text" minlength="6" maxlength="6" value="{!v.account.Pin_code__c}" messageWhenTooShort="Please enter valid 6digit Pincode"/>
                </div>&nbsp;
                <div class="slds-col slds-size_1-of-2">
                    <lightning:textarea name="Description" value="{!v.account.Description}" label="Description"  />
                </div>
            </div>-->
        </aura:if>
        <aura:if isTrue="{!v.showUpload}">
            <c:photoUploadComponent recordId="{!v.account.Id}" />
        </aura:if>
    </div>
    
    
    <div class="modal-footer slds-modal__footer slds-size_1-of-1">
        <aura:if isTrue="{!v.showAccount}">
            <button class="slds-button slds-button_neutral" onclick="{!c.closeExpense}">Cancel</button>
            <aura:if isTrue="{!!v.showUpdate}">
                <button class="slds-button slds-button_brand" onclick="{!c.dosave}">Save and Next</button>
            </aura:if>
            <aura:if isTrue="{!v.showUpdate}">
                <button class="slds-button slds-button_neutral" onclick="{!c.donext}">Next</button>
                <button class="slds-button slds-button_brand" onclick="{!c.doUpdate}">Update and Next</button>
            </aura:if>
        </aura:if>
        
        <aura:if isTrue="{!v.showUpload}">
            <button class="slds-button slds-button_neutral" onclick="{!c.gotoRecord}">Save</button>
            <button class="slds-button slds-button_neutral" onclick="{!c.doPrevious}">Previous</button>
            <!--<button class="slds-button slds-button_brand" onclick="{!c.doSubmit}">Submit for Approval</button>-->
        </aura:if>
    </div>
    
    <div>
        <aura:if isTrue="{!v.spinner}">
            <lightning:spinner class="spins" size="large" variant="brand" alternativeText="Loading" />
        </aura:if>
    </div>
    
</aura:component>