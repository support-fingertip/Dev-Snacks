<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Sales_Invoice_Validation</fullName>
    <active>true</active>
    <errorConditionFormula>AND( ISPICKVAL( Type__c , &apos;Against Invoice&apos;),   ISBLANK( Sales_Invoice__c )  )</errorConditionFormula>
    <errorDisplayField>Sales_Invoice__c</errorDisplayField>
    <errorMessage>Sales Invoice cannot be empty.</errorMessage>
</ValidationRule>
