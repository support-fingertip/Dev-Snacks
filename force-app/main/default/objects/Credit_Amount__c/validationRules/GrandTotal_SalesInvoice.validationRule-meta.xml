<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>GrandTotal_SalesInvoice</fullName>
    <active>true</active>
    <errorConditionFormula>IF( Sales_Invoice__r.Grand_Total_after_discount__c &lt; Amount__c,TRUE,FALSE)</errorConditionFormula>
    <errorDisplayField>Amount__c</errorDisplayField>
    <errorMessage>The grand total of invoice must be equal to or greater than the specified amount.</errorMessage>
</ValidationRule>
