<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Return_Amount_value</fullName>
    <active>true</active>
    <errorConditionFormula>IF(Return__r.Grand_Total_after_discount__c &lt;  Amount__c,TRUE,FALSE)</errorConditionFormula>
    <errorDisplayField>Return__c</errorDisplayField>
    <errorMessage>The specified amount must be less than or equal to the return amount.</errorMessage>
</ValidationRule>
