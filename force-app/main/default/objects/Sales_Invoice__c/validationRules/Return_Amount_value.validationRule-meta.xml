<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Return_Amount_value</fullName>
    <active>true</active>
    <errorConditionFormula>IF(Grand_Total__c  &lt; Against_Customer_Return_Amount__c ,TRUE,FALSE)</errorConditionFormula>
    <errorMessage>The Invoice Grand Total Amount must be equal to or greater than the customer return amount.</errorMessage>
</ValidationRule>
