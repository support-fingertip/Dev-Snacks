<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Pending_Amount__c</fullName>
    <externalId>false</externalId>
    <formula>If(NOT(ISPICKVAL( Sales_Invoice_Status__c ,&apos;Cancelled&apos; )),  
			ROUND((Invoice_Total__c  -  Amount_Received__c) -  Total_Return_Amount__c,0)-Journal_Amount__c- Against_Customer_Return_Amount__c, 0)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Pending Amount</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Currency</type>
</CustomField>
