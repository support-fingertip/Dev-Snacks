@IsTest
public class StockTrackingReportPdfCtrlTest {

    @IsTest
    static void testPdfControllerConstructor() {

       
        Route__c route = new Route__c(
            Name = 'Test Route'
        );
        insert route;

      
        PageReference pageRef = Page.StockTrackingReportPdf;
        pageRef.getParameters().put('routeId', route.Id);
        pageRef.getParameters().put('from', String.valueOf(Date.today().addDays(-5)));
        pageRef.getParameters().put('to', String.valueOf(Date.today()));
  pageRef.getParameters().put('selectedCol', '');
     
        Test.setCurrentPage(pageRef);

        
        Test.startTest();
        StockTrackingReportPdfCtrl ctrl =
            new StockTrackingReportPdfCtrl();
        Test.stopTest();


        System.assertEquals(
            'Test Route',
            ctrl.routeName,
            'Route name should be populated'
        );

       
        System.assertNotEquals(
            null,
            ctrl.generatedBy,
            'Generated By should not be null'
        );

      
        System.assertNotEquals(
            null,
            ctrl.generatedOn,
            'Generated On should not be null'
        );

       
        System.assertNotEquals(
            null,
            ctrl.fromDateStr,
            'From Date string should not be null'
        );
        System.assertNotEquals(
            null,
            ctrl.toDateStr,
            'To Date string should not be null'
        );

        
        System.assertNotEquals(
            null,
            ctrl.rows,
            'Rows list should be initialized'
        );
    }
}