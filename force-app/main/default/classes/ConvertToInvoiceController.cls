public with sharing class ConvertToInvoiceController {
    
    @AuraEnabled  
    public static Sales_order__c getSalesOrderRecord(Id recordId){
        Sales_order__c salesOrderRecord= [select Id,Status__c,Name,Route__c,Vehicle__c,Visit__c,Warehouse__c from Sales_order__c  where Id =:recordId Limit 1];
        return salesOrderRecord;
    }
    
    @AuraEnabled
    public static boolean checkCreditPeriod(Id recordId){
        
        system.debug('recordId=== '+recordId);
        Sales_order__c salesOrderRecord= [select Id,Status__c,Name,Route__c,Vehicle__c,Visit__c,Warehouse__c,Customer__c,Skip_Credit_Limit_For_Next_Order__c from Sales_order__c  
                                          where Id =:recordId Limit 1]; 
        Sales_Invoice__c salesInvoice = [select id,name,customer__c,pending_amount__c,Pending_Amount_SAP__c,invoice_date__c,Customer__r.Credit_period__c,Customer__r.Credit_Limit__c,Customer__r.Name
                                         from Sales_Invoice__c where Customer__c =: salesOrderRecord.Customer__c and Pending_Amount__c > 0 and invoice_date__c != null 
                                         order by Invoice_Date__c,createdDate asc nulls last limit 1];
        system.debug('salesInvoice : checkCreditPeriod'+salesInvoice);
        
        Integer salesInvoiceDateFromToday = salesInvoice.Invoice_Date__c.daysBetween(System.today());
        if(salesInvoiceDateFromToday > salesInvoice.Customer__r.Credit_period__c && salesOrderRecord.Skip_Credit_Limit_For_Next_Order__c==false){
            return true;
            
            // add here that credit period is  over.
        }
        return false;
    }
    
    @AuraEnabled
    public static Sales_Invoice__c createInvoice(Id recordId){
        Sales_order__c salesOrderRecord= [select Id,Status__c,Name,Customer__c,Customer__r.Id,trip__c,Route__c,Branch__c,Vehicle__c,Visit__c,Warehouse__c,Daily_logs__c from Sales_order__c
                                          where Id =:recordId Limit 1];
        
        List<Address__c> getAddress = [select Id,GST_No__c,Customer__c from Address__c where Address_Type__c =:'B' AND Customer__c =: salesOrderRecord.Customer__c Limit 1];
        system.debug('getAddress== '+getAddress);
        
        if(salesOrderRecord != null){
            Sales_Invoice__c salesInvoice = new Sales_Invoice__c();
            salesInvoice.Customer__c = salesOrderRecord.Customer__c;
            salesInvoice.Sales_Order__c = salesOrderRecord.Id;
            salesInvoice.Trip__c = salesOrderRecord.trip__c;
            salesInvoice.Route__c = salesOrderRecord.Route__c;
            salesInvoice.Branch__c = salesOrderRecord.Branch__c;
            salesInvoice.Warehouse__c = salesOrderRecord.Warehouse__c;
            salesInvoice.Vehicle__c = salesOrderRecord.Vehicle__c;
            salesInvoice.Visit__c = salesOrderRecord.Visit__c;
            salesInvoice.Daily_log__c = salesOrderRecord.Daily_logs__c;
            if(getAddress.size()>0){
                salesInvoice.Gstin__c = getAddress[0].GST_No__c;
            }
            Insert salesInvoice;
            system.debug('salesInvoice=== '+salesInvoice);
            return salesInvoice;
        }
        
        return null;
    }
    
    @AuraEnabled
    public static string createInvoiceItems(Id salesOrderId,Id salesInvoiceId){
        
        List<Sales_order_item__c> getSalesOrderItems = [select Id,Total__c,GST_Percentage__c,Product__c,Stock__c,Quantity__c,Unit_Price__c,Discount_Percent__c,
                                                        GST_Value__c,Total_after_discount__c,Sales_order__c from Sales_order_item__c 
                                                        where Sales_order__r.Id =: salesOrderId];
        system.debug('getSalesOrderItems=== '+getSalesOrderItems);
          decimal outstanding =0;
        List<Sales_Invoice_Item__c> salesInvoiceItems = new List<Sales_Invoice_Item__c>();
        if(getSalesOrderItems.size()>0){
            for(Sales_order_item__c salesOrderItem : getSalesOrderItems){
                
                Sales_Invoice_Item__c salesInvoiceItem =new Sales_Invoice_Item__c();
                salesInvoiceItem.Total__c= salesOrderItem.Total__c;
                outstanding += salesOrderItem.Total__c;
                salesInvoiceItem.GST_Percentage__c= salesOrderItem.GST_Percentage__c;
                salesInvoiceItem.GST_Value__c = salesOrderItem.GST_Value__c;
                salesInvoiceItem.Product__c= salesOrderItem.Product__c;
                salesInvoiceItem.Stock__c = salesOrderItem.Stock__c;
                salesInvoiceItem.Quantity__c= salesOrderItem.Quantity__c;
                salesInvoiceItem.Unit_Price__c = salesOrderItem.Unit_Price__c;
                salesInvoiceItem.Sales_Invoice__c= salesInvoiceId;
                salesInvoiceItem.Discount_Percent__c = salesOrderItem.Discount_Percent__c;
                salesInvoiceItem.Total_after_discount__c = salesOrderItem.Total_after_discount__c;
                salesInvoiceItems.add(salesInvoiceItem);
            }
            Insert salesInvoiceItems;
            system.debug('salesInvoiceItems=== '+salesInvoiceItems);
        }
        

        Sales_order__c salesOrderRecord= [select Id,Status__c,Name,Customer__c from Sales_order__c where Id =:salesOrderId];
        salesOrderRecord.Status__c = 'Converted';
        update salesOrderRecord;
        
        return salesOrderRecord.Name;
    }
  
