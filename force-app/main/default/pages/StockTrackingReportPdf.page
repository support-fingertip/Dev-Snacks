<apex:page controller="StockTrackingReportPdfCtrl"
           renderAs="pdf"
           showHeader="false"
           sidebar="false"
           applyHtmlTag="false">
    
    <html>
        <head>
            <style>
                @page {
                size: A4 landscape;
                margin: 18mm 10mm 14mm 10mm;
                }
                
                body {
                font-family: Arial, sans-serif;
                font-size: 10px;
                color: #111;
                }
                
                .header {
                border-bottom: 2px solid #222;
                padding-bottom: 8px;
                margin-bottom: 10px;
                }
                
                .title {
                font-size: 18px;
                font-weight: 700;
                margin: 0;
                padding: 0;
                }
                
                .meta {
                font-size: 10px;
                color: #555;
                margin-top: 4px;
                }
                
                .filters {
                margin-top: 8px;
                padding: 10px;
                border: 1px solid #cfcfcf;
                background: #f7f7f7;
                font-size: 12px;
                line-height: 1.4;
                }
                .filters b { font-weight: 700; }
                
                table {
                width: 100%;
                border-collapse: collapse;
                border-spacing: 0; /* Add this line */
                margin-top: 12px;
                border: 1px solid #444;
                -fs-table-paginate: paginate; /* Enable pagination for the table */
                }
                
                thead th {
                background: #e9ecef;
                border: 1px solid #444;
                padding: 7px 6px;
                font-weight: 700;
                font-size: 11px;
                vertical-align: bottom;
                page-break-before: always;  /* Forces header to be placed at the top of each page */
                }
                
                tbody td {
                border: 1px solid #666;
                padding: 6px 6px;
                font-size: 10px;
                vertical-align: top;
                }
                
                tbody tr:nth-child(even) td { background: #fafafa; }
                
                .num { text-align: right; }
                .wrap { white-space: normal; }
                .code { white-space: nowrap; }
                
                /* Prevent rows from breaking across pages */
                tbody tr { page-break-inside: avoid; }
                
                /* Repeat header on each page */
                thead { display: table-header-group; }
                
            </style>
        </head>
        
        <body>
            
            <div class="header">
                <div class="title">Stock Tracking Report&nbsp;&nbsp;stock_track</div>
                <div class="meta">
                    As of {!generatedOn} India Standard Time/IST &#8226; Generated by {!generatedBy}
                </div>
            </div>
            
            <div class="filters">
                <div><b>Date Field:</b> Date equals Custom ({!fromDateStr} to {!toDateStr})</div>
                <div><b>Data Filter Applied on :</b> {!selectedColumn}</div>
                <div style="margin-top:4px;"><b>Route:</b> Route Name equals <b>{!routeName}</b></div>
            </div>
            
            <table>
                <thead>
                    <tr>
                        <th class="code">Product code</th>
                        <th class="wrap">Product</th>
                        <th class="num">Opening<br/>Quantity</th>
                        <th class="num">Total stock<br/>Received</th>
                        <th class="num">Invoice<br/>cancellation</th>
                        <th class="num">Unsealed Quantity</th>
                        <th class="num">Salable<br/>Returns</th>
                        <th class="num">Total Saleable<br/>Quantity</th>
                        <th class="num">Sold<br/>Quantity</th>
                        <th class="num">Saleable Closing<br/>Quantity</th>
                        <th class="num">Damaged<br/>Quantity</th>
                        <th class="num">Total<br/>Quantity</th>
                    </tr>
                </thead>
                
                <tbody>
                    <apex:repeat value="{!rows}" var="r">
                        <tr>
                            <td class="code">{!r.productCode}</td>
                            <td class="wrap">{!r.productName}</td>
                            <td class="num">{!r.openingQty}</td>
                            <td class="num">{!r.totalStockReceived}</td>
                            <td class="num">{!r.invoiceCancellation}</td>
                            <td class="num">{!r.unsealedQty}</td>
                            <td class="num">{!r.saleableReturns}</td>
                            <td class="num">{!r.totalSaleableQty}</td>
                            <td class="num">{!r.soldQty}</td>
                            <td class="num">{!r.saleableClosingQty}</td>
                            <td class="num">{!r.damagedQty}</td>
                            <td class="num">{!r.totalQty}</td>
                        </tr>
                    </apex:repeat>
                </tbody>
            </table>
            
        </body>
    </html>
</apex:page>