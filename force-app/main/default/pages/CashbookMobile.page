<apex:page controller="CashbookController" showHeader="false" standardStylesheets="false"  applyBodyTag="false" applyHtmlTag="false"  >
    <html>
        <head>
            <meta http-equiv="Content-Type" content="text/html;charset=UTF-8" />
            <style type="text/css">
                @page {
                size:A4 portrait;
                border: 2px solid black;  
                h1 {text-align: center;}
                
                }
                table, th, td {
                border:.3px solid black;
                }
                  @media print {
                thead {display: table-header-group;} 
                tfoot {display: table-footer-group;}
                button {display: none;}
                body {margin: 0;}
                * {-webkit-print-color-adjust:exact;}
                }
            </style>
             <script>
            function printPage(){
                window.print();
            }
            </script>
        </head>
        
        <body >
            <div >
                <p style="text-align:Center;">
                    <apex:image url="{!$Resource.Ledger_logo}"/> 
                </p>
                
                <p style="text-align:Center ;font-size: 20px">
                    <b><u>Cashbook</u></b>
                </p>
                
                <apex:form >
                    
                    <table width="100%" style="border-collapse: collapse" class="slds-table">
                        <thead>
                        <!--<tr style="background-color:#ddd9c4;text-align:center">
                                <th colspan="5">Bangalore Department</th>
                        </tr>-->
                        <tr style="background-color:#ddd9c4;text-align:center">
                            <th rowspan="2">SL. NO.</th>
                            <th colspan="5">CASH BOOK</th>
                        </tr>
                        <tr style="background-color:#ddd9c4;text-align:center">
                            <th>DATE</th>
                            <th>PARTICULARS</th>
                            <th>CREDIT</th>
                            <th>DEBIT</th>
                            <th>BALANCE</th>
                        </tr>
                        <tr>
                            <td></td>
                            <td></td>
                            <td>OPENING BALANCE</td>
                            <td>{!OpeningBalance}</td>
                            <td></td>
                            <td></td>
                        </tr>
                            </thead>
                        <tbody>
                        
                        <apex:variable var="rowNo" value="{!0}"/>
                        
                        <apex:repeat value="{!wraplist}" var="w" id="theRepeat">
                            <tr>
                                <td> <apex:variable var="rowNo" value="{!rowNo+1}"/>{!rowNo}</td>
                                <td><apex:outputText value="{0,date,dd/MM/yy}"> <apex:param value="{!w.transDate}" /> </apex:outputText></td>
                                <td>{!w.Remarks}</td>
                                <td><apex:outputPanel rendered="{!IF(w.Status=='Debited',true,false)}">{!w.Amount}</apex:outputPanel></td>
                                <td><apex:outputPanel rendered="{!IF(w.Status=='Credited',true,false)}">{!w.Amount}</apex:outputPanel></td>
                                <td></td>
                            </tr>
                        </apex:repeat>
                  
                        <tr>
                            <td></td>
                            <td></td>
                            <td>Total</td>
                            <td>{!totalDr}</td>
                            <td>{!totalCr}</td>
                            <td>{!ClosingBalance}</td>
                            
                        </tr>
                        </tbody>
                    </table>
                    
                    <!--<apex:pageBlock >
                        
                        <apex:pageblockSection  collapsible="false" columns="2">                
                            <apex:pageBlockTable value="{!wraplist}" var="contWrap" id="table" border="1">
                                
                                <apex:column value="{!contWrap.Branch}"  headerValue="Contact Name" />
                                <apex:column value="{!contWrap.Route}" headerValue="Email"/>
                                <apex:column value="{!contWrap.From1 }" />
                                
                                <!-- <apex:column value="{!c.Name}" headerValue="Contact Name"/>
                                    <apex:column value="{!c.Email}" headerValue="Email"/>
                                    <apex:column value="{!c.Phone}" headerValue="Phone"/>
                            </apex:pageBlockTable>             
                        </apex:pageblockSection>
                    </apex:pageBlock>-->
                </apex:form>   
                <br/>
                <div style="width: 100%;text-align: center;">
                     <br/>
                 <button type="button" class="slds-button " onclick="printPage();">  Print this page </button>
                </div>
            </div>
        </body>
    </html>
</apex:page>