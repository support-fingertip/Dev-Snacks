<apex:page controller="CollectionSheetController" showHeader="false" standardStylesheets="false"  applyBodyTag="false" applyHtmlTag="false"    >
    <html>
        <head>
            <meta http-equiv="Content-Type" content="text/html;charset=UTF-8" />
            <style type="text/css">
                @page {
                size:A4 portrait;
                border: 2px solid black;  
                h1 {text-align: center;}
                
                }
                table, th, td {
                border:.3px solid black;
                 word-wrap: break-word;
                }
                  @media print {
                thead {display: table-header-group;} 
                tfoot {display: table-footer-group;}
                button {display: none;}
                body {margin: 0;}
                * {-webkit-print-color-adjust:exact;}
                }
            </style>
             <script>
            function printPage(){
                window.print();
            }
            </script>
        </head>
        
        <body>
            <div>
                <p style="text-align:Center;">
                    <apex:image url="{!$Resource.Ledger_logo}"/> 
                </p>
                <p style="text-align:Center ;font-size: 20px">
                    <b><u>Collection Sheet</u></b>
                </p>
                
                <apex:form >
                    <table width="100%" class="slds-table" style="border-collapse: collapse">
                        <thead>
                        <tr style="background-color:#ddd9c4; text-align: center;">
                            <th  width="5%">SL. NO.</th>
                            <th width="10%">NAME OF PARTY</th>
                             <th width="15%">Ph no</th>
                            <th width="10%">PLACE</th>
                            <th width="10%">BILL NO</th>
                            <th width="10%">SALE AMT</th>
                            <th width="10%">CH NO</th>
                            <th width="10%">DATE</th>
                            <th width="10%">CH AMT</th>
                            <th width="10%">NEW AMT</th>
                           
                        </tr>
                        </thead>
                        <apex:variable var="rowNo" value="{!0}"/>
                        <tbody>
                        <apex:repeat value="{!salesInvoices}" var="inv" id="theRepeat">
                            <tr style="text-align: center;">
                                <td> <apex:variable var="rowNo" value="{!rowNo+1}"/>{!rowNo}</td>
                                <td>{!inv.PartyName}</td>
                                 <td>{!inv.Phone}</td>
                                <td>{!inv.Place}</td>
                                <td>{!inv.InvoiceNo}</td>
                                <td>{!inv.SaleAmount}</td>
                                <td>{!inv.CheckNo}</td>
                                <td><apex:outputText value="{0,date,dd/MM/yy}"> <apex:param value="{!inv.invDate}" /> </apex:outputText></td>
                                <td>{!inv.ChequeAmount}</td>
                                <td>{!inv.CashAmount}</td>
                               
                            </tr>
                        </apex:repeat>
                        <tr style="text-align:center">
                            <th></th>
                            <th>TOTAL</th>
                            <th></th>
                            <th></th>
                            <th>{!TotalSalesAmount}</th>
                            <th></th>
                            <th></th>
                            <th>{!totalChequeCollection}</th>
                            <th>{!totalCashCollection}</th>
                            <th></th>
                        </tr>
                          </tbody>
                    </table>
                    
                </apex:form>   
                <br/>
                <div>
                    <p><strong>TOTAL SALE :&nbsp;</strong>{!TotalSalesAmount}</p>
                    <p><strong>TOTAL CHEQUE :&nbsp;</strong>{!totalChequeCollection}</p>
                    <p><strong>TOTAL CASH :&nbsp;</strong>{!totalCashCollection}</p>
                    <p><strong>TOTAL EXPENSE :&nbsp;</strong>{!totalExpense}</p>
                    <p><strong>CASH IN HAND :&nbsp;</strong>{!ClosingBalance}</p>
                </div>
            </div>
            <div style="width: 100%;text-align: center;">
                     <br/>
                 <button type="button" class="slds-button " onclick="printPage();">  Print this page </button>
                </div>
        </body>
    </html>
</apex:page>