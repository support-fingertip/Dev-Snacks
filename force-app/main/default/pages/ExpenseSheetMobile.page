<apex:page controller="ExpenseSheetController" showHeader="false" standardStylesheets="false"  applyBodyTag="false" applyHtmlTag="false" >
    <html>
        <head>
            <meta http-equiv="Content-Type" content="text/html;charset=UTF-8" />
            <style type="text/css">
                @page {
                size:A4 portrait;
                border: 2px solid black;  
                h1 {text-align: center;}
                
                }
                table, th, td {
                border:.3px solid black;
                }
                  @media print {
                thead {display: table-header-group;} 
                tfoot {display: table-footer-group;}
                button {display: none;}
                body {margin: 0;}
                * {-webkit-print-color-adjust:exact;}
                }
            </style>
             <script>
            function printPage(){
                window.print();
            }
            </script>
        </head>
        
        <body >
            <div >
                <p style="text-align:Center;">
                    <apex:image url="{!$Resource.Ledger_logo}"/> 
                </p>
                
                <p style="text-align:Center ;font-size: 20px">
                    <b><u>Expense Sheet</u></b>
                </p>
                
                <apex:form >
                    
                    <table width="100%" class="slds-table" style="border-collapse: collapse">
                       <thead>
                        <tr style="background-color:#ddd9c4;text-align:center">
                            <th colspan="9">EXPENSE SHEET</th>
                        </tr>
                        <tr style="background-color:#ddd9c4;text-align:center">
                            <th>DATE</th>
                            <th>Sale</th>
                            <th>Opening Balance</th>
                            <th>Particulars</th>
                             <th>Amount</th>
                            <th>Total Amount</th>
                            <th>Particulars</th>
                             <th>Expense</th>
                            <th>Closing Balance</th>
                        </tr>
                        </thead>
                        <tbody>
                        
                        <apex:repeat value="{!wraplist}" var="w" id="theRepeat">
                            <tr style="text-align: center;">
                                 
                                <td><apex:outputText value="{0,date,dd/MM/yy}"> <apex:param value="{!w.transDate}" /> </apex:outputText></td>
                                <td><apex:outputText value="{!w.saleAmount}" > </apex:outputText></td>
                                 <td><apex:outputText value="{!w.OpeningBalance}" > </apex:outputText></td>
                                <td><apex:outputText value="{!w.SalesMan}" > </apex:outputText></td>
                                 <td><apex:outputText value="{!w.Amount}" > </apex:outputText></td>
                                 <td><apex:outputText value="{!w.totalAmount}" > </apex:outputText></td>
                                <td><apex:outputText value="{!w.Particulars}" > </apex:outputText></td>
                                <td><apex:outputText value="{!w.totalExp}" > </apex:outputText></td>
                                <td><apex:outputText value="{!w.ClosingBalance}" > </apex:outputText></td>
                             
                               
                            </tr>
                        </apex:repeat>
                        
                        </tbody>
                        
                    </table>
                    
                 
                </apex:form>   
                <br/>
                <div style="width: 100%;text-align: center;">
                     <br/>
                 <button type="button" class="slds-button " onclick="printPage();">  Print this page </button>
                </div>
                
            </div>
        </body>
    </html>
</apex:page>